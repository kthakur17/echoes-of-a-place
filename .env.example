# ── Server-side secrets (NEVER exposed to the browser) ──────────────────────
# Google Gemini API key — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Gemini model to use for all generation (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Firebase Admin SDK service account, base64-encoded JSON.
# Firebase Console → Project Settings → Service accounts → Generate new private key,
# then base64-encode the whole JSON file:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("serviceAccountKey.json"))
#   bash:       base64 -w0 serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_B64=base64-encoded-service-account-json

# ── Client-side Firebase config (safe to expose; security enforced by rules) ─
# Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-web-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
