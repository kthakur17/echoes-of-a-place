rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users may read their own data. All WRITES to journey entries and
    // storybooks happen exclusively through the server (Admin SDK bypasses
    // these rules), so clients get read-only access to their own documents
    // and no access to anyone else's.

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;

      match /journeyEntries/{entryId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /storybooks/{storybookId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }
    }

    // Default deny for anything not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
